{
  "name": "@faceair/opencode-fusion",
  "version": "0.2.1",
  "description": "Multi-model fusion plugin for OpenCode: goal mode, sidekick delegation, reviewer, and dynamic mid-session routing.",
  "type": "module",
  "license": "MIT",
  "author": "faceair",
  "homepage": "https://github.com/faceair/opencode-fusion#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faceair/opencode-fusion.git"
  },
  "bugs": {
    "url": "https://github.com/faceair/opencode-fusion/issues"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "ai-agent",
    "multi-agent",
    "multi-model"
  ],
  "packageManager": "bun@1.3.4",
  "engines": {
    "opencode": ">=1.17.11"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh.md",
    "LICENSE"
  ],
  "main": "./dist/server.js",
  "exports": {
    "./server": {
      "import": "./dist/server.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/server.ts --outdir ./dist --target bun --external @opencode-ai/plugin --external effect --external zod",
    "prepack": "bun run build",
    "prepublishOnly": "bun run typecheck && bun run test:unit",
    "test": "bun run test:unit",
    "test:unit": "bun test src/__tests__/autocontinue.test.ts src/__tests__/goal.test.ts src/__tests__/recall.test.ts src/__tests__/taskid.test.ts src/__tests__/server.test.ts",
    "test:e2e": "bun run build && bun test src/__tests__/e2e/",
    "typecheck": "tsc --noEmit",
    "dev": "bun build ./src/server.ts --outdir ./dist --target bun --external @opencode-ai/plugin --external effect --external zod --watch"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.11",
    "effect": "^3.21.2",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "typescript": "^5.7.0"
  }
}
